# FinOps Engine — environment variables
# Copy to .env.local for local dev. In production, configure these in Vercel /
# Railway project settings (NOT committed).

# --- Server-side only (used by api/generate.js and api/anthropic-generate.js) ---
# Google Gemini API key.
API_KEY=

# Anthropic Claude API key.
ANTHROPIC_API_KEY=

# --- Public (exposed to the browser via Vite's import.meta.env) ---
# Vercel Blob URL for the FinOps tactics database JSON. Public read URL, so
# safe to ship to clients. Leave blank to fall back to the bundled tactics file.
VITE_FINOPS_TACTICS_URL=
