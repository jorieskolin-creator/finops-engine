# FinOps Engine — environment variables
# Copy to .env.local for local dev. In production, configure these in Vercel /
# Railway project settings (NOT committed).

# --- Server-side only ---
# Google Gemini API key. Used by api/generate.js for all AI calls
# (Phase 0 DLP scan, Phase 1 batch audits, Phase 3 strategy synthesis).
GEMINI_API_KEY=

# Anthropic Claude key. Currently DISABLED — the engine routes all AI
# traffic through Gemini for technical testing. Uncomment + populate if
# you re-enable the Anthropic path (callOpusStrategy in
# src/services/anthropicService.ts) and wire it back into geminiService.ts.
# ANTHROPIC_API_KEY=

# --- Public (exposed to the browser via Vite's import.meta.env) ---
# Vercel Blob URL for the FinOps tactics database JSON. Public read URL,
# safe to ship to clients. Leave blank to use the bundled local fallback.
VITE_FINOPS_TACTICS_URL=
